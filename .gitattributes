# Force LF line endings for all text files (prevents CRLF on Windows checkouts)
* text=auto eol=lf

# Shell scripts must always be LF
*.sh text eol=lf

# PowerShell can stay CRLF on Windows
*.ps1 text eol=crlf
*.psm1 text eol=crlf

# Bicep, YAML, config — LF
*.bicep text eol=lf
*.bicepparam text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf
*.j2 text eol=lf

# Binaries — no conversion
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary

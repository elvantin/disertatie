# Nginx configuration for SC MEDIA SRL Backend API
# Managed by Ansible - do not edit manually

server {
    listen {{ app_listen_port }};
    server_name {{ app_server_name }};

    root {{ app_root }};
    index index.json;

    # Default content type for API
    default_type application/json;

    # CORS headers for cross-origin requests from WordPress
    add_header Access-Control-Allow-Origin "*" always;
    add_header Access-Control-Allow-Methods "GET, OPTIONS" always;
    add_header Access-Control-Allow-Headers "Content-Type" always;

    # Health check endpoint
    location /health {
        access_log off;
        return 200 '{"status":"ok","service":"mediasrl-api","host":"{{ inventory_hostname }}","timestamp":"$time_iso8601"}';
    }

    # API root - serves index.json
    location = /api/ {
        try_files /api/index.json =404;
    }

    # API endpoints - serve static JSON files
    location /api/services {
        try_files /api/services.json =404;
    }

    location /api/clients {
        try_files /api/clients.json =404;
    }

    location /api/projects {
        try_files /api/projects.json =404;
    }

    location /api/team {
        try_files /api/team.json =404;
    }

    location /api/stats {
        try_files /api/stats.json =404;
    }

    # Default - return 404 for unmapped routes
    location / {
        return 404 '{"error":"not_found","message":"Endpoint not found. See GET /api/ for available endpoints."}';
    }

    # Access and error logs
    access_log /var/log/nginx/app-access.log;
    error_log /var/log/nginx/app-error.log;
}

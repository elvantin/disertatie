<?php
/**
 * WordPress Configuration File - Managed by Ansible
 *
 * @package WordPress
 */

// ** Reverse proxy trust (nginx on vm-web-01 terminates SSL, proxies HTTP internally) **
// Tell WordPress the connection IS HTTPS even though nginx forwards it over plain HTTP.
// Without this, WordPress generates http:// URLs and all external redirects break.
if ( isset( $_SERVER['HTTP_X_FORWARDED_PROTO'] ) && $_SERVER['HTTP_X_FORWARDED_PROTO'] === 'https' ) {
    $_SERVER['HTTPS']       = 'on';
    $_SERVER['SERVER_PORT'] = 443;
}

// ** Site URL constants — always override DB values to prevent IP-based redirects **
// These constants take precedence over wp_options siteurl/home entries.
define( 'WP_HOME',    '{{ wordpress_site_url }}' );
define( 'WP_SITEURL', '{{ wordpress_site_url }}' );

// ** MySQL settings ** //
define( 'DB_NAME', '{{ wordpress_db_name }}' );
define( 'DB_USER', '{{ wordpress_db_user }}' );
define( 'DB_PASSWORD', '{{ wordpress_db_password }}' );
define( 'DB_HOST', '{{ wordpress_db_host }}:{{ wordpress_db_port }}' );
define( 'DB_CHARSET', 'utf8mb4' );
define( 'DB_COLLATE', '' );

// ** Authentication Unique Keys and Salts ** //
define( 'AUTH_KEY',         '{{ wordpress_auth_key }}' );
define( 'SECURE_AUTH_KEY',  '{{ wordpress_secure_auth_key }}' );
define( 'LOGGED_IN_KEY',    '{{ wordpress_logged_in_key }}' );
define( 'NONCE_KEY',        '{{ wordpress_nonce_key }}' );
define( 'AUTH_SALT',        '{{ wordpress_auth_salt }}' );
define( 'SECURE_AUTH_SALT', '{{ wordpress_secure_auth_salt }}' );
define( 'LOGGED_IN_SALT',   '{{ wordpress_logged_in_salt }}' );
define( 'NONCE_SALT',       '{{ wordpress_nonce_salt }}' );

// ** WordPress Database Table prefix ** //
$table_prefix = 'wp_';

// ** WordPress debugging mode ** //
define( 'WP_DEBUG', false );
define( 'WP_DEBUG_LOG', false );
define( 'WP_DEBUG_DISPLAY', false );

// ** Performance optimizations ** //
define( 'WP_MEMORY_LIMIT', '256M' );
define( 'WP_MAX_MEMORY_LIMIT', '512M' );
define( 'WP_POST_REVISIONS', 5 );
define( 'AUTOSAVE_INTERVAL', 300 );
define( 'EMPTY_TRASH_DAYS', 7 );

// ** Security enhancements ** //
define( 'DISALLOW_FILE_EDIT', true );
define( 'DISALLOW_FILE_MODS', false );
define( 'FORCE_SSL_ADMIN', true );  // SSL terminates at nginx proxy (vm-web-01)

// ** Absolute path to WordPress directory ** //
if ( ! defined( 'ABSPATH' ) ) {
    define( 'ABSPATH', __DIR__ . '/' );
}

// ** Sets up WordPress vars and included files ** //
require_once ABSPATH . 'wp-settings.php';

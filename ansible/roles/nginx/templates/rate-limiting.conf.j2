# ============================================================
# nginx Rate Limiting — Zone Definitions
# /etc/nginx/conf.d/rate-limiting.conf
# Managed by Ansible (nginx role, nginx_rate_limiting_enabled=true)
# Included automatically via: include /etc/nginx/conf.d/*.conf;
# ============================================================

# Status code for rate-limited requests
limit_req_status 429;
limit_conn_status 429;

# Shared connection tracking zone (per IP)
limit_conn_zone $binary_remote_addr zone=conn_per_ip:10m;

# ── Rate Limit Zones ──────────────────────────────────────────────────────────

# WordPress login page: 5 requests/minute (brute-force protection)
# Allows a burst of 3 before rate limiting kicks in
limit_req_zone $binary_remote_addr zone=wp_login:10m rate=5r/m;

# WordPress admin: 10 requests/minute
limit_req_zone $binary_remote_addr zone=wp_admin:10m rate=10r/m;

# XML-RPC: 2 requests/minute (almost always scanners/bots)
limit_req_zone $binary_remote_addr zone=xmlrpc:10m rate=2r/m;

# REST API: 60 requests/minute per IP
limit_req_zone $binary_remote_addr zone=api:10m rate=60r/m;

# General traffic: 200 requests/second (global DoS protection)
limit_req_zone $binary_remote_addr zone=global:10m rate=200r/s;

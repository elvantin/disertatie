# Nginx HTTPS reverse proxy configuration for SC MEDIA SRL
# Managed by Ansible
# vm-web-01: single entry point with SSL termination

# Upstream definitions
upstream wordpress_backend {
    server {{ hostvars['vm-cms-01']['ansible_host'] }}:80;   # vm-cms-01 (WordPress) - resolved dynamically
}

upstream app_backend {
    server {{ hostvars['vm-app-01']['ansible_host'] }}:8080;  # vm-app-01 (REST API) - resolved dynamically
}

# HTTP → HTTPS redirect (+ ACME challenge for certificate renewal)
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    server_name {{ website_domain }} {{ ansible_hostname }} {{ ansible_fqdn | default('_') }};

    # ACME challenge for Let's Encrypt renewal
    location /.well-known/acme-challenge/ {
        root {{ certbot_webroot }};
        allow all;
    }

    # Redirect all other HTTP traffic to HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS server (main)
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;

    server_name {{ website_domain }} {{ ansible_hostname }} {{ ansible_fqdn | default('_') }};

    # SSL certificate (Let's Encrypt)
    ssl_certificate {{ nginx_ssl_certificate }};
    ssl_certificate_key {{ nginx_ssl_certificate_key }};

    # OCSP stapling
    ssl_stapling on;
    ssl_stapling_verify on;
    resolver 8.8.8.8 8.8.4.4 valid=300s;
    resolver_timeout 5s;

    # HSTS (force HTTPS for 1 year)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Access and error logs
    access_log /var/www/mediasrl/logs/access.log main;
    error_log /var/www/mediasrl/logs/error.log warn;

    # Client upload size (WordPress media uploads)
    client_max_body_size 64M;

    # Security: Deny access to hidden files (except .well-known)
    location ~ /\.(?!well-known) {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Proxy to application server (vm-app-01)
    location /api/ {
        proxy_pass http://app_backend/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }

    # Health check endpoint (local, no proxy)
    location /health {
        access_log off;
        return 200 "OK\n";
        add_header Content-Type text/plain;
    }

    # All other traffic → WordPress CMS (vm-cms-01)
    location / {
        proxy_pass http://wordpress_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 120s;

        # WebSocket support (for wp-admin live preview)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Error pages
    error_page 502 503 504 /50x.html;
    location = /50x.html {
        root /var/www/mediasrl/html;
        internal;
    }
}

      },
      {
        "Title": "CMS direct (vm-cms-01)",
        "URL": "http://{{ hostvars['vm-cms-01']['ansible_host'] | default('vm-cms-01') }}/",
        "Placement": "menu",
        "Folder": "Instrumente interne"
      },
      {
        "Title": "CMS Admin direct (vm-cms-01)",
        "URL": "http://{{ hostvars['vm-cms-01']['ansible_host'] | default('vm-cms-01') }}/wp-admin",
        "Placement": "menu",
        "Folder": "Instrumente interne"
      },
      {
        "Title": "App Server direct (vm-app-01:8080)",
        "URL": "http://{{ hostvars['vm-app-01']['ansible_host'] | default('vm-app-01') }}:8080/api/",
        "Placement": "menu",
        "Folder": "Instrumente interne"
      }

    ]

      "Locked": false,
      "StartPage": "homepage"
    },

    "Bookmarks": [

      {
        "Title": "SC MEDIA SRL — Website",
        "URL": "https://{{ website_domain }}/",
        "Placement": "toolbar"
      },

      {
        "Title": "WordPress Admin",
        "URL": "https://{{ website_domain }}/wp-admin",
        "Placement": "toolbar"
      },

      {
        "Title": "API Overview",
        "URL": "https://{{ website_domain }}/api/",
        "Placement": "toolbar",
        "Folder": "API"
      },
      {
        "Title": "Servicii",
        "URL": "https://{{ website_domain }}/api/services",
        "Placement": "toolbar",
        "Folder": "API"
      },
      {
        "Title": "Clienti",
        "URL": "https://{{ website_domain }}/api/clients",
        "Placement": "toolbar",
        "Folder": "API"
      },
      {
        "Title": "Proiecte",
        "URL": "https://{{ website_domain }}/api/projects",
        "Placement": "toolbar",
        "Folder": "API"
      },
      {
        "Title": "Echipa",
        "URL": "https://{{ website_domain }}/api/team",
        "Placement": "toolbar",
        "Folder": "API"
      },
      {
        "Title": "Statistici",
        "URL": "https://{{ website_domain }}/api/stats",
        "Placement": "toolbar",
        "Folder": "API"
      },

      {
        "Title": "SSL Labs — SSL Test",
        "URL": "https://www.ssllabs.com/ssltest/",
        "Placement": "toolbar",
        "Folder": "Security"
      },

      {
        "Title": "Azure Portal",
        "URL": "https://portal.azure.com",
        "Placement": "toolbar",
        "Folder": "Azure"
      },
      {
        "Title": "Azure Monitor",
        "URL": "https://portal.azure.com/#view/Microsoft_Azure_Monitoring/AzureMonitoringBrowseBlade/~/overview",
        "Placement": "toolbar",
        "Folder": "Azure"
      },
      {
        "Title": "Resource Group — Productie",
        "URL": "https://portal.azure.com/#resource/subscriptions/{{ ansible_env.ARM_SUBSCRIPTION_ID | default('') }}/resourceGroups/rg-mediasrl-productie-swedencentral/overview",

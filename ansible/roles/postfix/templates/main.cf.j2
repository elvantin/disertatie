# Postfix main configuration - Managed by Ansible

# Network settings
myhostname = {{ ansible_hostname }}.{{ ansible_domain | default('mediasrl.local') }}
mydomain = {{ ansible_domain | default('mediasrl.local') }}
myorigin = $mydomain
inet_interfaces = all
inet_protocols = ipv4

# Network restrictions
mynetworks = 10.10.10.0/24, 127.0.0.0/8
mydestination = $myhostname, localhost.$mydomain, localhost, $mydomain
relay_domains = $mydestination

# Mailbox settings
home_mailbox = Maildir/
mailbox_size_limit = 512000000
message_size_limit = 50000000

# SMTP banner (security - hide version)
smtpd_banner = $myhostname ESMTP

# TLS parameters (when certificates are configured)
# smtpd_use_tls = yes
# smtpd_tls_cert_file = /etc/pki/tls/certs/postfix.pem
# smtpd_tls_key_file = /etc/pki/tls/private/postfix.key
# smtpd_tls_security_level = may
# smtpd_tls_loglevel = 1

# SMTP client TLS
smtp_use_tls = yes
smtp_tls_security_level = may
smtp_tls_loglevel = 1

# SASL authentication
smtpd_sasl_auth_enable = no
smtpd_sasl_type = cyrus
smtpd_sasl_path = smtpd

# Anti-spam and security restrictions
smtpd_helo_required = yes
smtpd_delay_reject = yes
smtpd_helo_restrictions =
    permit_mynetworks,
    reject_invalid_helo_hostname,
    reject_non_fqdn_helo_hostname

smtpd_sender_restrictions =
    permit_mynetworks,
    reject_non_fqdn_sender,
    reject_unknown_sender_domain

smtpd_recipient_restrictions =
    permit_mynetworks,
    reject_non_fqdn_recipient,
    reject_unknown_recipient_domain,
    reject_unauth_destination,
    permit

# Rate limiting
smtpd_client_connection_rate_limit = 50
smtpd_error_sleep_time = 5s
smtpd_soft_error_limit = 5
smtpd_hard_error_limit = 10

# Queue settings
maximal_queue_lifetime = 1d
bounce_queue_lifetime = 1d

# Logging
maillog_file = /var/log/postfix.log
